# NCBI (Entrez, GEO, GenBank) — une seule clé pour toutes les APIs NCBI
# Créer sur : https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_EMAIL=your.email@example.com
NCBI_API_KEY=

# GEO — même clé NCBI (Entrez db=gds pour métadonnées, FTP pour matrices brutes)
# Docs : https://www.ncbi.nlm.nih.gov/geo/info/geo_paccess.html
# GEO_BASE_FTP=ftp://ftp.ncbi.nlm.nih.gov/geo/series

# Ensembl / Ensembl Plants — pas de clé requise (API publique)
# Docs : https://rest.ensembl.org/  |  https://plants.ensembl.org/info/data/rest.html
# Wiki : https://github.com/Ensembl/ensembl-rest/wiki
# ENSEMBL_REST_URL=https://rest.ensembl.org

# Expression Atlas (EBI) — pas de clé requise (API publique)
# Bulk : https://www.ebi.ac.uk/gxa/json/experiments
# Single-cell : https://www.ebi.ac.uk/gxa/sc/json/
# Aide : https://ebi-gene-expression-group.github.io/atlas-help-pages/help-page.html
# EXPRESSION_ATLAS_BASE_URL=https://www.ebi.ac.uk/gxa
