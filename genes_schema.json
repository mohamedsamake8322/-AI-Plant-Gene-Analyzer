{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Genes Database Schema",
  "type": "object",
  "required": ["metadata", "genes"],
  "properties": {
    "metadata": {
      "type": "object",
      "properties": {
        "version": {"type": "string"},
        "last_update": {"type": "string", "format": "date-time"},
        "sources": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": true
    },
    "genes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["gene_id", "symbol", "sequence", "sequence_type"],
        "properties": {
          "gene_id": {"type": "string"},
          "symbol": {"type": "string"},
          "organism": {"type": "string"},
          "traits": {"type": "array", "items": {"type": "string"}},
          "sequence": {"type": "string"},
          "sequence_type": {"type": "string", "enum": ["dna", "protein"]},
          "description": {"type": "string"},
          "external_links": {
            "type": "object",
            "properties": {
              "ncbi": {"type": "string"},
              "ensembl": {"type": "string"},
              "uniprot": {"type": "string"}
            },
            "additionalProperties": true
          },
          "expression_profiles": {"type": "array"},
          "pathways": {"type": "array"},
          "publications": {"type": "array"},
          "length": {"type": "integer"},
          "source": {"type": "string"},
          "source_url": {"type": "string"},
          "date_added": {"type": "string", "format": "date-time"},
          "version": {"type": ["string", "integer"]},
          "annotations": {"type": "object"},
          "notes": {"type": "string"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
